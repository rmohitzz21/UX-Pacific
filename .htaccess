# ==================================================
# UX Pacific - Production .htaccess
# ==================================================

Options -Indexes
RewriteEngine On

# Block dangerous admin scripts from non-local clients (defense in depth; PHP production_guard also applies).
RewriteCond %{REQUEST_URI} admin/api/(setup_db|seed_db|test_crud|test_upload)\.php [NC]
RewriteCond %{REMOTE_ADDR} !^127\.0\.0\.1$
RewriteCond %{REMOTE_ADDR} !^::1$
RewriteRule ^ - [F,L]

# ─── Security Headers ───
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Remove PHP version header
    Header always unset X-Powered-By
    
    # No caching for API responses (admin)
    <FilesMatch "\.(php)$">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
</IfModule>

# ─── Force HTTPS (uncomment on production with SSL) ───
# RewriteCond %{HTTPS} !=on
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── HSTS (uncomment after confirming HTTPS works) ───
# <IfModule mod_headers.c>
#     Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
# </IfModule>

# ─── Block sensitive files ───
<FilesMatch "(^\.env|^\.git|composer\.json|composer\.lock|package\.json|package-lock\.json|\.md$)">
    Require all denied
</FilesMatch>

# ─── Block direct access to includes ───
<FilesMatch "^(db_credentials|db\.local|database_config|database|config)\.php$">
    Require all denied
</FilesMatch>

# ─── Custom 404 page ───
ErrorDocument 404 /404.php

# ─── 1. Redirect index.php / index to root ───
RewriteCond %{THE_REQUEST} \s/+(?:UX_Pacific/)?index\.php[\s?] [NC]
RewriteRule ^ / [R=301,L]

# ─── 2. Redirect .php URLs to clean URLs (301) ───
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ─── 3. Internally serve clean URLs from .php files ───
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

# ─── Protect configuration directories ───
RewriteRule ^includes/(db_credentials|db\.local|database_config)\.php$ - [F,L]
