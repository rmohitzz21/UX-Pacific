# ==================================================
# UX Pacific - Production .htaccess
# ==================================================

Options -Indexes
RewriteEngine On

# Block dangerous development/maintenance endpoints if they are accidentally uploaded.
RewriteRule ^admin/api/(setup_db|seed_db|test_crud|test_upload)\.php$ - [F,L,NC]

# Block dev/build scripts from web access.
RewriteRule ^(generate-sitemap|generate-hub-pages|inject-loc-sections)\.php$ - [F,L,NC]
RewriteRule ^(inject-loc-sections\.ps1|verify-links\.ps1|broken-links-report\.csv|inject-loc-sections\.log)$ - [F,L,NC]

# Block runtime/private files and dependency internals from web access.
RewriteRule ^vendor/ - [F,L,NC]
RewriteRule ^storage/logs/ - [F,L,NC]
RewriteRule ^(mailer\.php|test|temp\.html|empty_files\.py|clear_files\.bat)$ - [F,L,NC]

# ─── Security Headers ───
<IfModule mod_headers.c>
    # Prevent MIME type sniffing
    Header always set X-Content-Type-Options "nosniff"
    
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    
    # XSS Protection (legacy browsers)
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Permissions Policy
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    
    # Remove PHP version header
    Header always unset X-Powered-By
    
    # No caching for admin/API endpoints only
    <FilesMatch "^admin/">
        Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
    </FilesMatch>
    # Location pages and public pages: allow 1-hour browser cache
    <FilesMatch "^ui-ux-design-agency-in-.*\.php$">
        Header set Cache-Control "public, max-age=3600, s-maxage=86400"
    </FilesMatch>
</IfModule>

# ─── Force HTTPS (production only — skips localhost) ───
RewriteCond %{HTTPS} !=on
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
RewriteCond %{HTTP_HOST} !^::1
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ─── HSTS (production only) ───
<IfModule mod_headers.c>
    <If "%{HTTP_HOST} != 'localhost'">
        Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
    </If>
</IfModule>

# ─── Block sensitive files ───
<FilesMatch "(^\.env|^\.git|composer\.json|composer\.lock|package\.json|package-lock\.json|\.md$|\.sql$|\.log$|\.bak$|\.backup$)">
    Require all denied
</FilesMatch>

# ─── Block direct access to includes ───
<FilesMatch "^(db_credentials|db\.local|database_config|database|config)\.php$">
    Require all denied
</FilesMatch>

# ─── Custom 404 page ───
ErrorDocument 404 /404.php

# ─── 1. Redirect index.php / index to root ───
RewriteCond %{THE_REQUEST} \s/+(?:UX_Pacific/)?index\.php[\s?] [NC]
RewriteRule ^ / [R=301,L]

# ─── 2. Redirect .php URLs to clean URLs (301) ───
# Admin panel: POST + 301 becomes GET (sign-out, forms, API mutations break).
RewriteCond %{THE_REQUEST} !admin/ [NC]
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ /%1 [R=301,L,NE]

# ─── 3. Internally serve clean URLs from .php files ───
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+)$ $1.php [L,QSA]

# ─── Protect configuration directories ───
RewriteRule ^includes/(db_credentials|db\.local|database_config)\.php$ - [F,L]
