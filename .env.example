# UX Pacific - copy to `.env` next to `index.php` on the server.
# Never commit real credentials.

# Live PHP on Hostinger/cPanel normally connects to MySQL on the same server.
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cpanelprefix_database_name
DB_USER=cpanelprefix_mysql_user

# Always quote passwords that contain #, spaces, or other special characters.
DB_PASS="replace_with_rotated_password"
DB_CHARSET=utf8mb4

APP_ENV=production
APP_DEBUG=false

# Recommended on live hosting so local override values can never be selected.
UXP_FORCE_PRODUCTION=1

# Optional local-only overrides. These are used only for localhost/127.0.0.1
# requests, unless UXP_FORCE_PRODUCTION=1 is set.
# DB_HOST_LOCAL=localhost
# DB_PORT_LOCAL=3306
# DB_NAME_LOCAL=ux_pacific_local
# DB_USER_LOCAL=root
# DB_PASS_LOCAL=""

# Temporary diagnostics. Enable only while debugging, then turn off.
# APP_DEBUG=true
# UXP_LOG_DB_ERRORS=1

# Optional SMTP settings if mail is driven from .env.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=
# SMTP_SECURE=ssl
# SMTP_FROM_EMAIL=noreply@example.com
# SMTP_FROM_NAME="UX Pacific"

# Optional if `.env` cannot live next to index.php:
# Apache SetEnv UXP_ENV_FILE /home/user/private/uxp.env
